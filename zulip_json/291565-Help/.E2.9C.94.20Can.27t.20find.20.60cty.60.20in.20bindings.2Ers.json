lang_arg</span><span class=\"p\">(</span><span class=\"s\">\"-DKBUILD_MODNAME=</span><span class=\"se\">\\\"</span><span class=\"s\">ovpn_dco_rust</span><span class=\"se\">\\\"</span><span class=\"s\">\"</span><span class=\"p\">)</span>\n<span class=\"w\">        </span><span class=\"p\">.</span><span class=\"n\">use_core</span><span class=\"p\">()</span>\n<span class=\"w\">        </span><span class=\"p\">.</span><span class=\"n\">ctypes_prefix</span><span class=\"p\">(</span><span class=\"s\">\"::cty\"</span><span class=\"p\">)</span>\n<span class=\"w\">        </span><span class=\"p\">.</span><span class=\"n\">generate</span><span class=\"p\">()</span>\n<span class=\"w\">        </span><span class=\"p\">.</span><span class=\"n\">expect</span><span class=\"p\">(</span><span class=\"s\">\"Unable to generate bindings\"</span><span class=\"p\">);</span>\n\n<span class=\"w\">    </span><span class=\"kd\">let</span><span class=\"w\"> </span><span class=\"n\">out_path</span><span class=\"w\"> </span><span class=\"o\">=</span><span class=\"w\"> </span><span class=\"n\">PathBuf</span><span class=\"p\">::</span><span class=\"n\">from</span><span class=\"p\">(</span><span class=\"n\">env</span><span class=\"p\">::</span><span class=\"n\">var</span><span class=\"p\">(</span><span class=\"s\">\"OUT_DIR\"</span><span class=\"p\">).</span><span class=\"n\">unwrap</span><span class=\"p\">());</span>\n<span class=\"w\">    </span><span class=\"kd\">let</span><span class=\"w\"> </span><span class=\"n\">bindings_path</span><span class=\"w\"> </span><span class=\"o\">=</span><span class=\"w\"> </span><span class=\"n\">out_path</span><span class=\"p\">.</span><span class=\"n\">join</span><span class=\"p\">(</span><span class=\"s\">\"bindings.rs\"</span><span class=\"p\">);</span>\n\n<span class=\"w\">    </span><span class=\"n\">bindings</span>\n<span class=\"w\">        </span><span class=\"p\">.</span><span class=\"n\">write_to_file</span><span class=\"p\">(</span><span class=\"o\">&amp;</span><span class=\"n\">bindings_path</span><span class=\"p\">)</span>\n<span class=\"w\">        </span><span class=\"p\">.</span><span class=\"n\">expect</span><span class=\"p\">(</span><span class=\"s\">\"Couldn't write bindings!\"</span><span class=\"p\">);</span>\n\n<span class=\"w\">    </span><span class=\"kd\">let</span><span class=\"w\"> </span><span class=\"k\">mut</span><span class=\"w\"> </span><span class=\"n\">bindings_content</span><span class=\"w\"> </span><span class=\"o\">=</span>\n<span class=\"w\">        </span><span class=\"n\">fs</span><span class=\"p\">::</span><span class=\"n\">read_to_string</span><span class=\"p\">(</span><span class=\"o\">&amp;</span><span class=\"n\">bindings_path</span><span class=\"p\">).</span><span class=\"n\">expect</span><span class=\"p\">(</span><span class=\"s\">\"Failed to read bindings.rs\"</span><span class=\"p\">);</span>\n\n<span class=\"w\">    </span><span class=\"c1\">// Remove problematic #[derive(Debug)] for types that do not implement Debug</span>\n<span class=\"w\">    </span><span class=\"n\">bindings_content</span><span class=\"w\"> </span><span class=\"o\">=</span><span class=\"w\"> </span><span class=\"n\">bindings_content</span><span class=\"p\">.</span><span class=\"n\">replace</span><span class=\"p\">(</span><span class=\"s\">\"#[derive(Debug)]\"</span><span class=\"p\">,</span><span class=\"w\"> </span><span class=\"s\">\"\"</span><span class=\"p\">);</span>\n\n<span class=\"w\">    </span><span class=\"n\">fs</span><span class=\"p\">::</span><span class=\"n\">write</span><span class=\"p\">(</span><span class=\"o\">&amp;</span><span class=\"n\">bindings_path</span><span class=\"p\">,</span><span class=\"w\"> </span><span class=\"n\">bindings_content</span><span class=\"p\">).</span><span class=\"n\">expect</span><span class=\"p\">(</span><span class=\"s\">\"Failed to write modified bindings.rs\"</span><span class=\"p\">);</span>\n\n<span class=\"w\">    </span><span class=\"kd\">let</span><span class=\"w\"> </span><span class=\"n\">final_bindings_path</span><span class=\"w\"> </span><span class=\"o\">=</span>\n<span class=\"w\">        </span><span class=\"n\">PathBuf</span><span class=\"p\">::</span><span class=\"n\">from</span><span class=\"p\">(</span><span class=\"n\">env</span><span class=\"p\">::</span><span class=\"n\">var</span><span class=\"p\">(</span><span class=\"s\">\"CARGO_MANIFEST_DIR\"</span><span class=\"p\">).</span><span class=\"n\">unwrap</span><span class=\"p\">()).</span><span class=\"n\">join</span><span class=\"p\">(</span><span class=\"s\">\"bindings.rs\"</span><span class=\"p\">);</span>\n<span class=\"w\">    </span><span class=\"n\">fs</span><span class=\"p\">::</span><span class=\"n\">copy</span><span class=\"p\">(</span><span class=\"o\">&amp;</span><span class=\"n\">bindings_path</span><span class=\"p\">,</span><span class=\"w\"> </span><span class=\"o\">&amp;</span><span class=\"n\">final_bindings_path</span><span class=\"p\">)</span>\n<span class=\"w\">        </span><span class=\"p\">.</span><span class=\"n\">expect</span><span class=\"p\">(</span><span class=\"s\">\"Failed to copy bindings.rs to crate root\"</span><span class=\"p\">);</span>\n<span class=\"p\">}</span>\n</code></pre></div>\n<p><a href=\"http://lib.rs\">lib.rs</a></p>\n<div class=\"codehilite\" data-code-language=\"Rust\"><pre><span></span><code><span class=\"cp\">#![no_main]</span>\n<span class=\"cp\">#![allow(improper_ctypes)]</span>\n<span class=\"cp\">#![allow(non_upper_case_globals)]</span>\n<span class=\"cp\">#![allow(warnings)]</span>\n<span class=\"cp\">#![no_std]</span>\n\n<span class=\"k\">use</span><span class=\"w\"> </span><span class=\"n\">core</span><span class=\"p\">::</span><span class=\"n\">panic</span><span class=\"p\">::</span><span class=\"n\">PanicInfo</span><span class=\"p\">;</span>\n\n<span class=\"fm\">include!</span><span class=\"p\">(</span><span class=\"s\">\"bindings.rs\"</span><span class=\"p\">);</span>\n\n<span clas