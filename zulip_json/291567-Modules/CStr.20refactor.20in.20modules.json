=\"p\">{</span>\n<span class=\"w\">         </span><span class=\"kd\">let</span><span class=\"w\"> </span><span class=\"n\">new_value</span><span class=\"w\"> </span><span class=\"o\">=</span><span class=\"w\"> </span><span class=\"n\">T</span><span class=\"p\">::</span><span class=\"n\">try_from_param_arg</span><span class=\"p\">(</span><span class=\"n\">arg</span><span class=\"p\">)</span><span class=\"o\">?</span><span class=\"p\">;</span>\n<span class=\"n\">diff</span><span class=\"w\"> </span><span class=\"o\">--</span><span class=\"n\">git</span><span class=\"w\"> </span><span class=\"n\">a</span><span class=\"o\">/</span><span class=\"n\">rust</span><span class=\"o\">/</span><span class=\"n\">macros</span><span class=\"o\">/</span><span class=\"n\">module</span><span class=\"p\">.</span><span class=\"n\">rs</span><span class=\"w\"> </span><span class=\"n\">b</span><span class=\"o\">/</span><span class=\"n\">rust</span><span class=\"o\">/</span><span class=\"n\">macros</span><span class=\"o\">/</span><span class=\"n\">module</span><span class=\"p\">.</span><span class=\"n\">rs</span>\n<span class=\"n\">index</span><span class=\"w\"> </span><span class=\"n\">d62e9c1e2a898</span><span class=\"o\">..</span><span class=\"n\">decb0849f3d33</span><span class=\"w\"> </span><span class=\"mi\">100644</span>\n<span class=\"o\">---</span><span class=\"w\"> </span><span class=\"n\">a</span><span class=\"o\">/</span><span class=\"n\">rust</span><span class=\"o\">/</span><span class=\"n\">macros</span><span class=\"o\">/</span><span class=\"n\">module</span><span class=\"p\">.</span><span class=\"n\">rs</span>\n<span class=\"o\">+++</span><span class=\"w\"> </span><span class=\"n\">b</span><span class=\"o\">/</span><span class=\"n\">rust</span><span class=\"o\">/</span><span class=\"n\">macros</span><span class=\"o\">/</span><span class=\"n\">module</span><span class=\"p\">.</span><span class=\"n\">rs</span>\n<span class=\"o\">@@</span><span class=\"w\"> </span><span class=\"o\">-</span><span class=\"mi\">133</span><span class=\"p\">,</span><span class=\"mi\">10</span><span class=\"w\"> </span><span class=\"o\">+</span><span class=\"mi\">133</span><span class=\"p\">,</span><span class=\"mi\">10</span><span class=\"w\"> </span><span class=\"o\">@@</span><span class=\"w\"> </span><span class=\"k\">fn</span><span class=\"w\"> </span><span class=\"nf\">emit_params</span><span class=\"p\">(</span><span class=\"o\">&amp;</span><span class=\"k\">mut</span><span class=\"w\"> </span><span class=\"bp\">self</span><span class=\"p\">,</span><span class=\"w\"> </span><span class=\"n\">info</span><span class=\"p\">:</span><span class=\"w\"> </span><span class=\"kp\">&amp;</span><span class=\"nc\">ModuleInfo</span><span class=\"p\">)</span><span class=\"w\"> </span><span class=\"p\">{</span>\n<span class=\"w\">                         </span><span class=\"p\">::</span><span class=\"n\">kernel</span><span class=\"p\">::</span><span class=\"n\">module_param</span><span class=\"p\">::</span><span class=\"n\">KernelParam</span><span class=\"p\">::</span><span class=\"n\">new</span><span class=\"p\">(</span>\n<span class=\"w\">                             </span><span class=\"p\">::</span><span class=\"n\">kernel</span><span class=\"p\">::</span><span class=\"n\">bindings</span><span class=\"p\">::</span><span class=\"n\">kernel_param</span><span class=\"w\"> </span><span class=\"p\">{{</span>\n<span class=\"w\">                                 </span><span class=\"n\">name</span><span class=\"p\">:</span><span class=\"w\"> </span><span class=\"nc\">if</span><span class=\"w\"> </span><span class=\"p\">::</span><span class=\"n\">core</span><span class=\"p\">::</span><span class=\"fm\">cfg!</span><span class=\"p\">(</span><span class=\"n\">MODULE</span><span class=\"p\">)</span><span class=\"w\"> </span><span class=\"p\">{{</span>\n<span class=\"o\">-</span><span class=\"w\">                                    </span><span class=\"p\">::</span><span class=\"n\">kernel</span><span class=\"p\">::</span><span class=\"n\">c_str</span><span class=\"o\">!</span><span class=\"p\">(</span><span class=\"err\">\\</span><span class=\"s\">\"{param_name}</span><span class=\"se\">\\\"</span><span class=\"s\">).as_bytes_with_nul()</span>\n<span class=\"s\">+                                    ::kernel::c_str!(</span><span class=\"se\">\\\"</span><span class=\"s\">{param_name}</span><span class=\"se\">\\\"</span><span class=\"s\">).to_bytes_with_nul()</span>\n<span class=\"s\">                                 }} else {{</span>\n<span class=\"s\">                                     ::kernel::c_str!(</span><span class=\"se\">\\\"</span><span class=\"s\">{module_name}.{param_name}</span><span class=\"se\">\\\"</span><span class=\"s\">)</span>\n<span class=\"s\">-                                        .as_bytes_with_nul()</span>\n<span class=\"s\">+                                        .to_bytes_with_nul()</span>\n<span class=\"s\">                                 }}.as_ptr(),</span>\n<span class=\"s\">                                 // SAFETY: `__this_module` is constructed by the kernel at load</span>\n<span class=\"s\">                                 // time and will not be freed until the module is unloaded.</span>\n</code></pre></div>",
